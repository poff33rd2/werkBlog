{% extends "base.njk" %}

{% block content %}
<div class="page-header">
<img class="page-header-icon" src="https://res.cloudinary.com/dtkhwq0je/image/upload/v1764109364/werk-icon-keyboard_yfsuic.png" alt="Section icon"></img>
<h1>{{ title }}</h1>
</div>
<div> {{ content | safe }} </div>
<div class="collections-grid"> {% for uiux in collections.uiux %}
<a href="{{ uiux.url }}"><div class="blog-item-box">
<h2 class="blog-item-title">{{ uiux.data.title | safe }}</h2> 
<p>{{ uiux.data.description | safe }}</p>
</div>
</a>
{% endfor %} </div>
{% endblock content %}
